# Supabase: Dashboard → Project Settings → API
# Database / OpenAI vars will be required by later tickets.

# --- Supabase (Auth + API) — required for issue #2 ---

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Server ---

# Comma-separated browser origins allowed to call the API (CORS).
ALLOWED_ORIGINS=http://localhost:5173

# --- Postgres (Alembic + SQLAlchemy) ---

# Use the DIRECT/session connection (host: db.<ref>.supabase.co, or session pooler on port 5432).
# Do NOT use the transaction pooler URL (pooler.supabase.com).
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# --- OpenAI (needed once the LLM / embedding layer is wired up) ---

# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=1536
